{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs/typedoc",
  "readme": "none",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "hideGenerator": true,
  "intentionallyNotExported": ["Loop", "Stream"],
  "blockTags": [
    "@param",
    "@returns",
    "@return",
    "@throws",
    "@example",
    "@remarks",
    "@author",
    "@class",
    "@classdesc",
    "@constructor",
    "@this"
  ]
}
